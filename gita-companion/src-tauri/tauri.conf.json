{
  "$schema": "https://schema.tauri.app/config/2",

  "productName": "Gita Companion",
  "version": "1.0.0",
  "identifier": "com.gitacompanion.app",

  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },

  "app": {
    "windows": [
      {
        "title": "Gita Companion",
        "width": 1100,
        "height": 720,
        "minWidth": 760,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
      "enable": true,
      "scope": ["$TEMP/**"]
    }
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  },

  "plugins": {}
}
